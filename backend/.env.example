# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://cryptopay:cryptopay@db:5432/cryptopay

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1

# JWT (RS256 — production; leave blank for HS256 dev fallback)
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
JWT_SIGNING_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081

# Payment provider · "daraja" (Safaricom · primary) or "sasapay" (fallback,
# code present but URL routes commented out as of April 2026).
PAYMENT_PROVIDER=daraja

# M-Pesa Daraja API
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=
MPESA_B2C_SHORTCODE=
MPESA_CALLBACK_BASE_URL=https://your-domain.com
MPESA_CERT_PATH=certs/sandbox.pem
MPESA_ALLOWED_IPS=196.201.214.0/24,196.201.213.0/24,196.201.212.0/24,192.168.0.0/16,127.0.0.0/8
# Audit HIGH-2: dedicated HMAC key for the per-tx callback URL token.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# Production refuses to boot if PAYMENT_PROVIDER=daraja and this is empty.
MPESA_CALLBACK_HMAC_KEY=

# SasaPay (alternative provider · DISABLED while Daraja is the active rail)
# To re-enable: set PAYMENT_PROVIDER=sasapay AND uncomment the URL routes
# in config/urls.py + apps/mpesa/urls.py AND set both secrets below.
SASAPAY_ENVIRONMENT=sandbox
SASAPAY_CLIENT_ID=
SASAPAY_CLIENT_SECRET=
SASAPAY_MERCHANT_CODE=
SASAPAY_CALLBACK_URL=https://your-domain.com/api/v1/sasapay/callback/
SASAPAY_ALLOWED_IPS=192.168.0.0/16,127.0.0.0/8
# Audit CRITICAL-1: SasaPay webhook authentication. At least one of the two
# below must be set when PAYMENT_PROVIDER=sasapay (production guard refuses
# the configuration otherwise).
#   SASAPAY_WEBHOOK_SECRET     · matches the X-SasaPay-Signature header HMAC
#   SASAPAY_CALLBACK_HMAC_KEY  · per-tx URL-token HMAC (our own fallback)
SASAPAY_WEBHOOK_SECRET=
SASAPAY_CALLBACK_HMAC_KEY=

# Audit HIGH-1: dedicated key for at-rest TOTP secret encryption.
# Production refuses to boot when empty. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# After deploying the new key, run:
#   python manage.py migrate_totp_encryption --apply
# to rewrite any existing rows from the old SECRET_KEY-derived key.
TOTP_ENCRYPTION_KEY=

# Float / Circuit Breaker Thresholds (KES)
FLOAT_EMERGENCY_KES=200000
FLOAT_CRITICAL_KES=500000
FLOAT_RESUME_KES=800000
FLOAT_HEALTHY_KES=1500000
FLOAT_LARGE_PAYMENT_KES=50000

# Rebalancing
REBALANCE_MIN_KES=50000
REBALANCE_MAX_KES=2000000
REBALANCE_COOLDOWN_SECONDS=300
REBALANCE_EXECUTION_MODE=manual

# Unimatrix SMS (primary OTP/SMS provider)
UNIMTX_ACCESS_KEY=

# eSMS Africa (secondary SMS provider)
ESMS_API_KEY=
ESMS_ACCOUNT_ID=
ESMS_SENDER_ID=

# Africa's Talking (tertiary SMS fallback)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=CryptoPay

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:8081

# Price Feed APIs
COINGECKO_API_KEY=
CRYPTOCOMPARE_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=

# Yellow Card (Off-ramp)
YELLOW_CARD_API_KEY=
YELLOW_CARD_SECRET_KEY=
YELLOW_CARD_BASE_URL=https://sandbox.api.yellowcard.io/business

# Blockchain — Tron
TRON_API_KEY=
TRON_NETWORK=shasta

# Blockchain — Ethereum
ETH_RPC_URL=
ETH_NETWORK=sepolia

# Blockchain — Polygon
POLYGON_RPC_URL=
POLYGON_LOG_SCAN_RANGE=50

# Blockchain — Bitcoin
BTC_NETWORK=test3
BLOCKCYPHER_API_TOKEN=
# Backup token — keep an inactive token ready at accounts.blockcypher.com
# so you can rotate (flip the "active" flag on their dashboard) without a
# code change if the primary gets revoked or rate-limited.
BLOCKCYPHER_API_TOKEN_BACKUP=

# Blockchain — Solana
SOL_RPC_URL=https://api.devnet.solana.com
SOL_NETWORK=devnet

# ────── KMS Envelope Encryption (REQUIRED in production) ──────
# In production, KMS_ENABLED MUST be True. With KMS off, every encrypted
# blob falls back to a Fernet key derived from SECRET_KEY, which means a
# single SECRET_KEY leak decrypts every wallet. The production settings
# guard refuses configurations with KMS_ENABLED=False.
#
# Pick a provider:
#   aws · setup runbook docs/KMS-SETUP.md      · provision: bash scripts/setup-aws-kms.sh
#   gcp · setup runbook docs/KMS-SETUP-GCP.md  · provision: bash scripts/setup-gcp-kms.sh
KMS_ENABLED=False
KMS_PROVIDER=aws                  # aws | gcp
KMS_SEED_CACHE_TTL=300            # seconds the decrypted seed stays in process memory

# ─── AWS KMS (used when KMS_PROVIDER=aws) ───
KMS_KEY_ID=                       # e.g. alias/cpay-prod-wallet  OR  arn:aws:kms:af-south-1:<account>:key/<uuid>
KMS_REGION=af-south-1             # closest AWS region to Kenya
# AWS credentials for boto3 · only needed when KMS_PROVIDER=aws AND the
# host doesn't already have an attached IAM role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── GCP KMS (used when KMS_PROVIDER=gcp) ───
# Resource format:
#   projects/<project>/locations/<loc>/keyRings/<ring>/cryptoKeys/<key>
# Closest GCP region: africa-south1 (Johannesburg).
KMS_KEY_RESOURCE=
# Path to the service-account JSON file mounted on the host (the file
# must be owned by the runtime user and chmod 400). Only needed when
# KMS_PROVIDER=gcp AND the host isn't running on a GCP-managed
# workload-identity service.
GOOGLE_APPLICATION_CREDENTIALS=

# ────── HD Wallet seed ──────
# Pick exactly ONE source. In production, WALLET_ENCRYPTED_SEED is the only
# safe choice · the others put the BIP-39 phrase or raw seed in plaintext.
#
# Generate the encrypted blob with:
#     python manage.py encrypt_wallet_seed --verify
# After confirming, REMOVE the plaintext WALLET_MNEMONIC / WALLET_MASTER_SEED
# from the host. Keeping both defeats the purpose.
WALLET_ENCRYPTED_SEED=            # base64 envelope blob (production)
WALLET_MNEMONIC=                  # BIP-39 phrase (development only · NEVER commit)
WALLET_MASTER_SEED=               # 64-byte hex seed (development only · NEVER commit)

# Hot Wallet Addresses (destination for on-chain sweeps · public, safe to set)
HOT_WALLET_TRON=
HOT_WALLET_ETH=
HOT_WALLET_BTC=
HOT_WALLET_SOL=

# ────── Hot Wallet Private Keys ──────
# Pick ENCRYPTED variants in production · the plaintext variants only exist
# for local development and are refused at boot when KMS_ENABLED=True.
#
# Generate each encrypted blob with:
#     python manage.py encrypt_hot_wallet_key --chain tron --verify
#     python manage.py encrypt_hot_wallet_key --chain eth  --verify
#     python manage.py encrypt_hot_wallet_key --chain sol  --verify
# Then REMOVE the plaintext *_HOT_WALLET_PRIVATE_KEY values.

# Encrypted (production)
TRON_HOT_WALLET_ENCRYPTED=
ETH_HOT_WALLET_ENCRYPTED=
POLYGON_HOT_WALLET_ENCRYPTED=
SOL_HOT_WALLET_ENCRYPTED=
BTC_HOT_WALLET_ENCRYPTED=

# Plaintext (development only · NEVER set in production with KMS_ENABLED=True)
TRON_HOT_WALLET_PRIVATE_KEY=
ETH_HOT_WALLET_PRIVATE_KEY=
POLYGON_HOT_WALLET_PRIVATE_KEY=
SOL_HOT_WALLET_PRIVATE_KEY=
BTC_HOT_WALLET_PRIVATE_KEY=

# Smile Identity (KYC)
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_CALLBACK_URL=

# Prometheus
PROMETHEUS_MULTIPROC_DIR=

# Sentry (production)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# Email (production — Resend, SES, or SMTP)
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# Database Backup
# BACKUP_DIR=/var/backups/cryptopay
# AWS_S3_BUCKET=
# AWS_S3_PREFIX=backups/cryptopay

# Production SSL
# SECURE_SSL_REDIRECT=True
# DB_CONN_MAX_AGE=600

# Monitoring (Grafana)
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change-me-to-strong-password
