# ─────────────────────────────────────────────────────────────
# Cloudflare credentials for cache purging during deployment
# Copy to deploy/.env.cloudflare and fill in real values
#
# To get your Zone ID:
#   Cloudflare dashboard -> cpay.co.ke -> Overview -> right sidebar -> "Zone ID"
#
# To create an API token:
#   Cloudflare dashboard -> My Profile -> API Tokens -> Create Token
#   Use template: "Custom token"
#   Permissions: Zone > Cache Purge > Purge
#   Zone Resources: Include > Specific zone > cpay.co.ke
# ─────────────────────────────────────────────────────────────
CLOUDFLARE_ZONE_ID=your_zone_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_DOMAIN=cpay.co.ke
