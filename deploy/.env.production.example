# ─────────────────────────────────────────────────────────────
# CryptoPay — Production Environment Variables
# Copy to deploy/.env.production and fill in real values
# ─────────────────────────────────────────────────────────────

# ── Django ──────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-c-from-django.core.management.utils-import-get_random_secret_key-print-get_random_secret_key
DEBUG=False
ALLOWED_HOSTS=cpay.co.ke,www.cpay.co.ke,127.0.0.1
SECURE_SSL_REDIRECT=False
# Cloudflare handles SSL; Django sees HTTP from nginx. Set False to avoid redirect loops.

# ── Database (Postgres inside Docker, exposed on host:5433) ─
DATABASE_URL=postgres://cryptopay:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/cryptopay
POSTGRES_DB=cryptopay
POSTGRES_USER=cryptopay
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_CONN_MAX_AGE=600

# ── Redis (inside Docker, exposed on host:6380) ────────────
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/1

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://cpay.co.ke,https://www.cpay.co.ke

# ── Frontend URL (for email verification links) ────────────
FRONTEND_URL=https://cpay.co.ke

# ── JWT (RS256 recommended for production) ──────────────────
# Generate: openssl genrsa -out jwt_private.pem 2048
#           openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=/app/certs/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/certs/jwt_public.pem
JWT_SIGNING_KEY=

# ── M-Pesa Daraja API ──────────────────────────────────────
MPESA_ENVIRONMENT=production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_PASSWORD=
MPESA_B2C_SHORTCODE=
MPESA_CALLBACK_BASE_URL=https://cpay.co.ke
MPESA_CERT_PATH=/app/certs/production.pem
MPESA_ALLOWED_IPS=196.201.214.0/24,196.201.213.0/24,196.201.212.0/24

# ── Float / Circuit Breaker Thresholds (KES) ───────────────
FLOAT_EMERGENCY_KES=200000
FLOAT_CRITICAL_KES=500000
FLOAT_RESUME_KES=800000
FLOAT_HEALTHY_KES=1500000
FLOAT_LARGE_PAYMENT_KES=50000

# ── Rebalancing ────────────────────────────────────────────
REBALANCE_MIN_KES=50000
REBALANCE_MAX_KES=2000000
REBALANCE_COOLDOWN_SECONDS=300
REBALANCE_EXECUTION_MODE=manual

# ── Africa's Talking (SMS OTP) ─────────────────────────────
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=CryptoPay

# ── Price Feed APIs ────────────────────────────────────────
COINGECKO_API_KEY=
CRYPTOCOMPARE_API_KEY=

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Yellow Card (Off-ramp) ─────────────────────────────────
YELLOW_CARD_API_KEY=
YELLOW_CARD_SECRET_KEY=
YELLOW_CARD_BASE_URL=https://api.yellowcard.io/business

# ── Blockchain — Tron ──────────────────────────────────────
TRON_API_KEY=
TRON_NETWORK=mainnet

# ── Blockchain — Ethereum ──────────────────────────────────
ETH_RPC_URL=
ETH_NETWORK=mainnet

# ── Blockchain — Polygon ──────────────────────────────────
POLYGON_RPC_URL=
POLYGON_LOG_SCAN_RANGE=50

# ── Blockchain — Bitcoin ───────────────────────────────────
BTC_NETWORK=main
BLOCKCYPHER_API_TOKEN=

# ── Blockchain — Solana ────────────────────────────────────
SOL_RPC_URL=https://api.mainnet-beta.solana.com
SOL_NETWORK=mainnet

# ── HD Wallet (CRITICAL — never commit real values!) ───────
WALLET_MNEMONIC=
WALLET_MASTER_SEED=

# ── Hot Wallet Addresses ───────────────────────────────────
HOT_WALLET_TRON=
HOT_WALLET_ETH=
HOT_WALLET_BTC=
HOT_WALLET_SOL=

# ── Smile Identity (KYC) ──────────────────────────────────
SMILE_IDENTITY_PARTNER_ID=
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_CALLBACK_URL=https://cpay.co.ke/api/v1/kyc/callback/

# ── Email (Resend recommended — 3K/month free) ────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ── Sentry ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=production

# ── Gunicorn ───────────────────────────────────────────────
GUNICORN_WORKERS=3

# ── Prometheus ─────────────────────────────────────────────
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus

# ── Backup ─────────────────────────────────────────────────
# BACKUP_DIR=/var/backups/cryptopay
# AWS_S3_BUCKET=
# AWS_S3_PREFIX=backups/cryptopay
