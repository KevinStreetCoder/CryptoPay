{
  "expo": {
    "name": "CryptoPay",
    "slug": "cryptopay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "cryptopay",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060E1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ke.co.cryptopay.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "metamask",
          "trust",
          "safe",
          "rainbow",
          "phantom",
          "uniswap",
          "zerion"
        ],
        "NSCameraUsageDescription": "CryptoPay needs camera access for KYC identity verification.",
        "NSFaceIDUsageDescription": "CryptoPay uses Face ID for secure authentication."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ],
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhoneNumber",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeName",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          },
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeEmailAddress",
            "NSPrivacyCollectedDataTypeLinked": true,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "ke.co.cryptopay.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#10B981",
        "foregroundImage": "./assets/icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "INTERNET",
        "CAMERA",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "blockedPermissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "READ_CONTACTS",
        "WRITE_CONTACTS",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "READ_CALL_LOG",
        "WRITE_CALL_LOG",
        "READ_PHONE_STATE",
        "CALL_PHONE",
        "READ_SMS",
        "SEND_SMS",
        "RECEIVE_SMS",
        "RECORD_AUDIO",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "cryptopay"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.cpay.co.ke",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "CryptoPay"
    },
    "extra": {
      "API_URL": "https://cpay.co.ke/api/v1",
      "APP_ENV": "production",
      "privacyPolicyUrl": "https://cpay.co.ke/privacy",
      "termsOfServiceUrl": "https://cpay.co.ke/terms",
      "supportEmail": "support@cpay.co.ke",
      "googleWebClientId": "797403635202-t2i871kkg2qfsoq19appg47c6ud0c6ac.apps.googleusercontent.com",
      "googleAndroidClientId": "797403635202-bbokau8cna2nju3omuaktls8ko0ptv4c.apps.googleusercontent.com",
      "googleIosClientId": "",
      "eas": {
        "projectId": "3ca5c56b-30ff-454d-ad81-801f8d888db8"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-web-browser",
      "expo-notifications",
      "./queries.js"
    ]
  }
}
