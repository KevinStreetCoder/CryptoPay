{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "development",
        "API_URL": "http://localhost:8000/api/v1",
        "EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID": "34724557aafaf3b437889ff0a053cba9"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_ENV": "preview",
        "API_URL": "https://staging-api.cryptopay.co.ke/api/v1",
        "EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID": "34724557aafaf3b437889ff0a053cba9"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_ENV": "production",
        "API_URL": "https://api.cryptopay.co.ke/api/v1",
        "EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID": "34724557aafaf3b437889ff0a053cba9"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "developer@cryptopay.co.ke",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": true
      }
    }
  }
}
