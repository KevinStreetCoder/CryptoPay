{
  "uid": "cryptopay-overview",
  "title": "CryptoPay Overview",
  "tags": ["cryptopay"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(django_http_requests_total_by_method_total[5m])",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "HTTP Response Status Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(django_http_responses_total_by_status_total[5m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Error Rate (5xx)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m])) / sum(rate(django_http_responses_total_by_status_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 1 },
          { "color": "red", "value": 5 }
        ]}}
      }
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"cryptopay\"}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Transaction Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(cryptopay_transactions_total[5m])",
          "legendFormat": "{{type}} - {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "Payment Saga Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(cryptopay_payment_saga_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 saga"
        },
        {
          "expr": "histogram_quantile(0.50, rate(cryptopay_payment_saga_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 saga"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "M-Pesa Float Balance (KES)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "cryptopay_mpesa_float_balance_kes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyKES",
          "min": 0,
          "max": 10000000,
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 500000 },
            { "color": "green", "value": 2000000 }
          ]}
        }
      }
    },
    {
      "id": 9,
      "title": "Wallet Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 20 },
      "targets": [
        {
          "expr": "rate(cryptopay_wallet_operations_total[5m])",
          "legendFormat": "{{operation}} - {{currency}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Celery Task Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 20 },
      "targets": [
        {
          "expr": "celery_tasks_total",
          "legendFormat": "{{name}} - {{state}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Redis Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 12,
      "title": "PostgreSQL Row Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"cryptopay\"}[5m])",
          "legendFormat": "Inserts"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"cryptopay\"}[5m])",
          "legendFormat": "Updates"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"cryptopay\"}[5m])",
          "legendFormat": "Deletes"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 13,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "targets": [
        {
          "expr": "cryptopay_circuit_breaker_state",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF-OPEN", "color": "yellow" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39
}
